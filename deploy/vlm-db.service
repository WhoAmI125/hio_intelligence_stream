[Unit]
Description=VLM DB Server (SQLite Event Storage)
After=network.target

[Service]
Type=simple
User=vlmapp
Group=vlmapp
WorkingDirectory=/home/ubuntu/vlm_new_deploy
Environment=PYTHONPATH=/home/ubuntu/vlm_new_deploy
EnvironmentFile=/home/ubuntu/vlm_new_deploy/.env

ExecStart=/home/ubuntu/vlm_new_deploy/venv/bin/uvicorn \
    db_server.main:app \
    --host 127.0.0.1 \
    --port 8001 \
    --workers 1 \
    --timeout-keep-alive 65 \
    --log-level info

Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vlm-db

[Install]
WantedBy=multi-user.target

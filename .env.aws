# ============================================================
# Intelligent CCTV System - AWS Environment Variables
# Copy to .env on the AWS instance:
#   cp .env.aws .env
#   nano .env   # fill in GEMINI_API_KEY
# ============================================================

# --- Gemini API (Tier 2) ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Florence-2 (Tier 1) ---
FLORENCE_MODEL=microsoft/Florence-2-large
FLORENCE_BACKEND=pytorch
FLORENCE_DEVICE=cuda

# --- Server Ports ---
MODEL_SERVER_PORT=8000
DB_SERVER_PORT=8001
FRONTEND_SERVER_PORT=8002

# --- Inter-service URLs (internal, 127.0.0.1 only) ---
DB_SERVER_URL=http://127.0.0.1:8001
MODEL_SERVER_URL=http://127.0.0.1:8000

# --- Storage ---
DB_PATH=data/cctv_events.db
DB_MEDIA_ROOT=data/media_archive
MODEL_SERVER_DATA_DIR=data

# --- Detection Thresholds ---
CASH_THRESHOLD=0.30
VIOLENCE_THRESHOLD=0.30
FIRE_THRESHOLD=0.30

# --- RTSP Defaults ---
BASE_FPS=1.5
BURST_FPS=4.0
RTSP_TRANSPORT=tcp

# --- Logging ---
LOG_LEVEL=INFO

# --- LoRA Fine-tuning ---
LORA_ENABLED=false
LORA_DATA_COLLECTION=true
LORA_COLLECT_NORMAL_RATIO=0.0

# --- S3 (disabled by default, enable for cloud storage) ---
USE_S3=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-2
# AWS_STORAGE_BUCKET_NAME=

# --- FFmpeg ---
FFMPEG_PATH=ffmpeg
